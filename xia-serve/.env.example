# xia-serve configuration — copy to ".env" (or set these as environment
# variables). CLI flags override these. No secrets are baked into the SDK; you
# supply them here.

# Which built dist to serve:
XIA_DIST=../dist-demo

# LAN bind address + port (0.0.0.0 = reachable from other devices on the network):
XIA_HOST=0.0.0.0
XIA_PORT=8088

# --- Guest network egress (the sandbox's internet access) ---
# ON by default (full networking): the in-browser sandbox reaches the network
# THROUGH this machine. Set to 0/false/off (or pass --no-egress) to disable.
# Private/loopback targets are blocked unless XIA_ALLOW_PRIVATE=1 (so the box
# reaches the internet, not the host's LAN); restrict to a comma-separated host
# allowlist with XIA_ALLOW (empty = any public host).
XIA_EGRESS=1
XIA_ALLOW=
XIA_ALLOW_PRIVATE=0
XIA_MAX_BYTES=16777216
XIA_TIMEOUT=20000

# --- Host-side TLS CA (for the guest's HTTPS: curl/wget https in the sandbox) ---
# Point this at YOUR OWN CA file in the shape of tls-ca.example.json
# ({ "caPem": "...", "caKeyPem": "..." }). The SDK ships NO CA private key —
# generate a throwaway sandbox-local CA (see tls-ca.example.json) and reference
# it here. Leave empty to run without host TLS termination (HTTP egress and
# python's own HTTPS still work).
XIA_TLS_CA=

# Don't auto-open the control panel in a browser on start:
XIA_NO_OPEN=0
